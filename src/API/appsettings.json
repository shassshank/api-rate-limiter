{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  },
  "RateLimiting": {
  "WindowSeconds": 60,
  "MaxRequests": 3,
  "TokenBucketCapacity": 20,
  "TokenBucketRefillPerSecond": 0.5
},
"RateLimitPolicies": {
  "Rules": [
    {
      "PathPrefix": "/api/demo/fixed",
      "Strategy": "FixedWindow"
    },
    {
      "PathPrefix": "/api/demo/sliding",
      "Strategy": "SlidingWindow"
    },
    {
      "PathPrefix": "/api/demo/token",
      "Strategy": "TokenBucket"
    },
    {
      "PathPrefix": "/api",
      "Strategy": "FixedWindow"
    }
  ]
},
"ApiKeys": {
  "Keys": [
    {
      "Key": "FREE-111",
      "Name": "Free Plan Client",
      "Plan": "Free"
    },
    {
      "Key": "PRO-777",
      "Name": "Pro Plan Client",
      "Plan": "Pro"
    }
  ]
},
  "AllowedHosts": "*"
}